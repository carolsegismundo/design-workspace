# Copie para .env e preencha com os valores reais (NUNCA commite o .env).
# Project Settings → API no Supabase.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# API de chat (servidor — não use prefixo VITE_ para chaves secretas)
# Chave grátis: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_GENERATIVE_AI_API_KEY=

# Modelo (padrão no código: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Porta da API local (Vite faz proxy /api → esta porta). Padrão 3002.
# CHAT_API_PORT=3002
